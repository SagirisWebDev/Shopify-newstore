exports[`coffee-card placeholder branch snapshot > renders placeholder card when card_product is empty/null 1`] = `"<link rel="stylesheet" href="ASSET_URL_STUB"><div class="coffee-card coffee-card--placeholder"> <div class="coffee-card__media ratio" style="--ratio-percent: 100%;"> <svg class="placeholder-svg" aria-hidden="true"><rect width="100" height="100"/></svg> </div> <div class="coffee-card__info"> <h3 class="coffee-card__title">onboarding.product_title</h3> <div class="coffee-card__price">onboarding.product_price</div> </div> </div>"`;

exports[`coffee-card snapshot tests (AC1, AC2, AC5) > AC1: snapshot of normalised structural HTML 1`] = `"<link rel="stylesheet" href="ASSET_URL_STUB"><div class="coffee-card card-wrapper product-card-wrapper"> <a href="/products/ethiopia-yirgacheffe-natural" class="coffee-card__link full-unstyled-link"><div class="coffee-card__media ratio" style="--ratio-percent: 100%;"> <img srcset="SRCSET_STUB" src="SRC_STUB" alt="Ethiopia Yirgacheffe Natural coffee bag" width="600" height="600" loading="lazy" > </div><div class="coffee-card__info"> <h3 class="coffee-card__title">Ethiopia Yirgacheffe Natural</h3> <div class="coffee-card__price"> <span class="coffee-card__price-stub">$18.00</span> </div><ul class="coffee-card__chips" aria-label="Coffee attributes"><li class="coffee-card__chip coffee-card__chip--origin">Ethiopia,&nbsp;Yirgacheffe</li><li class="coffee-card__chip coffee-card__chip--process">Natural</li><li class="coffee-card__chip coffee-card__chip--roast">Light Roast</li></ul><p class="coffee-card__tasting-notes">Blueberry · Jasmine · Dark Chocolate</p></div> </a> </div>"`;
