{
  "sections": {
    "hero": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Specialty coffee, minus the attitude.",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "House-roasted single origins with the tasting notes actually explained. Roasted to order in Portland, OR.",
            "text_style": "body"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Shop Coffees",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": false,
            "button_label_2": "Subscribe & Save 25%",
            "button_link_2": "shopify://pages/subscribe",
            "button_style_secondary_2": true
          }
        }
      },
      "block_order": ["heading", "text", "button"],
      "settings": {
        "image_overlay_opacity": 50,
        "image_height": "large",
        "desktop_content_position": "middle-left",
        "show_text_box": false,
        "desktop_content_alignment": "left",
        "color_scheme": "scheme-3",
        "mobile_content_alignment": "left",
        "stack_images_on_mobile": false,
        "show_text_below": false
      }
    },
    "value_props": {
      "type": "multicolumn",
      "blocks": {
        "prop_explained": {
          "type": "column",
          "settings": {
            "title": "Specialty-grade, explained",
            "text": "<p>Every coffee comes with tasting notes, origin details, and brew recommendations written in plain language. No jargon, no judgment.</p>"
          }
        },
        "prop_fresh": {
          "type": "column",
          "settings": {
            "title": "Roasted to order",
            "text": "<p>We roast every bag the day it ships and pack it within 48 hours of your delivery date. Your coffee arrives at peak freshness, not peak shelf life.</p>"
          }
        },
        "prop_subscribe": {
          "type": "column",
          "settings": {
            "title": "Subscribe and save 25%",
            "text": "<p>Monthly delivery, your schedule. Swap coffees, skip a shipment, or cancel anytime from your subscriber portal — no hoops, no lock-in.</p>",
            "link_label": "See how it works",
            "link": "shopify://pages/subscribe"
          }
        }
      },
      "block_order": ["prop_explained", "prop_fresh", "prop_subscribe"],
      "settings": {
        "title": "",
        "heading_size": "h2",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "left",
        "background_style": "none",
        "color_scheme": "scheme-1",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "padding_top": 60,
        "padding_bottom": 36
      }
    },
    "featured_coffees": {
      "type": "featured-collection",
      "settings": {
        "title": "Our Coffees",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "show_view_all": true,
        "view_all_style": "button",
        "swipe_on_mobile": false,
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "subscribe_cta": {
      "type": "rich-text",
      "blocks": {
        "cta_heading": {
          "type": "heading",
          "settings": {
            "heading": "Never run out of good coffee.",
            "heading_size": "h2"
          }
        },
        "cta_text": {
          "type": "text",
          "settings": {
            "text": "<p>Subscribe to any coffee and save 25% on every order. We roast to order and deliver monthly — skip, pause, or swap anytime.</p>"
          }
        },
        "cta_button": {
          "type": "button",
          "settings": {
            "button_label": "See how subscriptions work",
            "button_link": "shopify://pages/subscribe",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["cta_heading", "cta_text", "cta_button"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "scheme-2",
        "full_width": true,
        "padding_top": 64,
        "padding_bottom": 64
      }
    }
  },
  "order": ["hero", "value_props", "featured_coffees", "subscribe_cta"]
}
