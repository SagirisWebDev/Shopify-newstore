{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coffee.metafields",
  "title": "Coffee Product Metafields",
  "description": "Required metafields for all bean products under the coffee namespace.",
  "type": "object",
  "required": [
    "origin_country",
    "origin_region",
    "producer_farm_name",
    "varietal",
    "altitude",
    "process",
    "roast_level",
    "roast_date",
    "tasting_notes",
    "brew_recommendations"
  ],
  "additionalProperties": false,
  "properties": {
    "origin_country": { "type": "string", "minLength": 1 },
    "origin_region": { "type": "string", "minLength": 1 },
    "producer_farm_name": { "type": "string", "minLength": 1 },
    "varietal": { "type": "string", "minLength": 1 },
    "altitude": { "type": "string", "minLength": 1 },
    "process": {
      "type": "string",
      "enum": ["washed", "natural", "honey", "other"]
    },
    "roast_level": {
      "type": "string",
      "enum": ["light", "medium", "dark"]
    },
    "roast_date": {
      "type": "string",
      "format": "date"
    },
    "tasting_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "brew_recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method", "description"],
        "additionalProperties": false,
        "properties": {
          "method": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decaf_method": {
      "type": "string",
      "minLength": 1,
      "description": "Required on decaf products only; omit on caffeinated products."
    }
  }
}
