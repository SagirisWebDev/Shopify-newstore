{{ 'section-product-meta.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="product-meta color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding page-width">

  {%- if section.settings.show_description and product.description != blank -%}
    <div class="product-meta__description rte">
      {{ product.description }}
    </div>
  {%- endif -%}

  <dl class="product-meta__list">

    {%- if section.settings.show_type and product.type != blank -%}
      <div class="product-meta__item">
        <dt class="product-meta__label caption-with-letter-spacing">Category</dt>
        <dd class="product-meta__value">{{ product.type | escape }}</dd>
      </div>
    {%- endif -%}

    {%- if section.settings.show_collections -%}
      {%- assign visible_collections = product.collections | where: 'handle', product.collections.first.handle -%}
      {%- assign all_collections = product.collections -%}
      {%- if all_collections.size > 0 -%}
        <div class="product-meta__item">
          <dt class="product-meta__label caption-with-letter-spacing">Collections</dt>
          <dd class="product-meta__value">
            {%- for collection in all_collections -%}
              <a href="{{ collection.url }}" class="product-meta__link">{{ collection.title | escape }}</a>
              {%- unless forloop.last -%},&nbsp;{%- endunless -%}
            {%- endfor -%}
          </dd>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.show_tags and product.tags.size > 0 -%}
      <div class="product-meta__item">
        <dt class="product-meta__label caption-with-letter-spacing">Tags</dt>
        <dd class="product-meta__value product-meta__tags">
          {%- for tag in product.tags -%}
            <a href="{{ routes.collections_url }}/all/{{ tag | handle }}" class="product-meta__tag">
              {{- tag | replace: '-', ' ' | escape -}}
            </a>
          {%- endfor -%}
        </dd>
      </div>
    {%- endif -%}

  </dl>

</div>

{% schema %}
{
  "name": "Product: Meta",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_type",
      "label": "Show category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collections",
      "label": "Show collections",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tags",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product: Meta"
    }
  ]
}
{% endschema %}
